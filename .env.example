# Copy this file to .env and fill in your values before running `make up`.
#
# The DATABASE_URL and REDIS_URL below use Docker service names (db, redis)
# which are required when running inside Docker Compose.
# If running the backend directly on the host, change them to localhost.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/productivity
REDIS_URL=redis://redis:6379/0
SECRET_KEY=your-secret-key-here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

ALLOWED_ORIGINS=http://localhost:3000
